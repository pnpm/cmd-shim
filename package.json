{
  "name": "@zkochan/cmd-shim",
  "version": "9.0.1",
  "description": "Used in pnpm for command line application support",
  "type": "module",
  "author": {
    "name": "Zoltan Kochan",
    "email": "zoltan.kochan@gmail.com",
    "url": "http://kochan.io"
  },
  "exports": {
    ".": "./index.js"
  },
  "scripts": {
    "clean": "tsc --build --clean",
    "build": "tsc --build --verbose --listEmittedFiles",
    "test:unit": "node --test test/test.js test/e2e.test.js",
    "test": "pnpm run build && pnpm run test:unit",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "index.d.ts",
    "index.d.ts.map",
    "index.js",
    "index.js.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pnpm/cmd-shim.git"
  },
  "license": "BSD-2-Clause",
  "dependencies": {
    "cmd-extension": "^1.0.2",
    "graceful-fs": "^4.2.11"
  },
  "devDependencies": {
    "@types/graceful-fs": "^4.1.9",
    "@types/node": "^18.19.87",
    "memfs": "^3.5.3",
    "tempy": "^1.0.1",
    "typescript": "^4.9.5"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.0.0-beta.2"
}

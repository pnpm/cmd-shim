{
  "include": [
    "**/*.js"
  ],
  "exclude": [
    "**/__snapshots__/**"
  ],
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node", "jest"],
    "noEmit": true
  },
  "references": [
    { "path": ".." }
  ]
}

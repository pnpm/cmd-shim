{
  "include": [
    "src/**/*"
  ],
  "exclude": [],
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "target": "esnext",
    "module": "nodenext",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./",
    "rootDir": "./src",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "strict": true,
    "moduleResolution": "nodenext",
    "types": ["node"]
  }
}
